# ============================================================
# FILE: .env.example
# Mô tả: Template biến môi trường cho hệ thống DWH Multi-Tenant
# Cách sử dụng: cp .env.example .env
#              Chỉnh sửa .env với giá trị thực tế
#              GHI CHÚ: KHÔNG commit .env vào Git (chứa mật khẩu)
# ============================================================

# ---- SQL Server Configuration ----
MSSQL_SERVER=mssql
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=YourStrongPassword123!@#  # Min 8 chars, 1 uppercase, 1 number, 1 symbol
MSSQL_DATABASE=DWH_MultiTenant

# ---- Auth Gateway (API) ----
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET_KEY=your-256-bit-random-secret-key-minimum-32-characters-long-do-not-share
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480  # 8 hours
REFRESH_TOKEN_EXPIRE_DAYS=7

# Default admin user (created on first run)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123
DEFAULT_ADMIN_ROLE=superadmin

# ---- SMTP Alert Configuration ----
# Gmail: Use App Password (16 chars), not regular password
# 1. Enable 2FA on Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password  # NOT your Gmail password
ALERT_FROM_EMAIL=dwh-alerts@company.com
ALERT_TO_EMAIL=admin@company.com

# ---- Slack Webhook (optional) ----
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ---- Apache Superset Configuration ----
SUPERSET_URL=http://superset:8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASS=YourStrongPassword123!@#
SUPERSET_SECRET_KEY=your-superset-secret-key-min-32-chars

# ---- Redis Configuration (Cache for Superset) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty if no password

# ---- Flask Frontend ----
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5000
FLASK_ENV=production
FLASK_SECRET_KEY=your-flask-secret-key-min-32-chars

# ---- Google Drive OAuth ----
# Create an OAuth Client in Google Cloud Console and add this redirect URI.
GOOGLE_DRIVE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/google-drive/callback

# ---- Backup Configuration ----
BACKUP_DIR=/backups/dwh
ARCHIVE_DIR=/backups/dwh/archive
RETENTION_DAYS_FULL=28
RETENTION_DAYS_DIFF=7
RETENTION_DAYS_LOG=2

# ---- Logging Configuration ----
LOG_LEVEL=INFO
LOG_DIR=/var/log/dwh
ETL_LOG_DIR=/data/dwh/logs

# ---- Docker Network (internal) ----
COMPOSE_PROJECT_NAME=dwh_multi_tenant

# ---- Feature Flags ----
ENABLE_REGISTRATION=true        # Allow new tenant registration
ENABLE_ETL_TRIGGER=true         # Allow manual ETL trigger via API
ENABLE_MONITORING_ALERTS=true   # Send email/Slack alerts
ENABLE_API_DOCS=true            # Expose Swagger docs at /api/docs

# ---- Nginx/HTTPS Configuration ----
DOMAIN_NAME=dwh.company.com     # Replace with your domain
NGINX_PORT_HTTP=80
NGINX_PORT_HTTPS=443
SSL_CERT_PATH=/etc/letsencrypt/live/dwh.company.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/dwh.company.com/privkey.pem
