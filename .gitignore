# ============================================================
# .gitignore — DWH Multi-Tenant Project
# ============================================================

# ── Secrets & Environment ───────────────────────────────────
.env
.env.local
.env.*.local
client_secret*.json
**/client_secret*.json
frontend/instance/
api/instance/
# .env.example được track để làm template

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.Python
.hypothesis/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/
.env/

# ── Testing & Coverage ──────────────────────────────────────
.pytest_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
nosetests.xml
*.cover

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
data/store_*/logs/
etl_orchestrator.log
pip-log.txt

# ── Data files (runtime) ────────────────────────────────────
# File gốc trong data/data/ được track (sample data cho demo)
# File runtime trong store_* bị ignore (do ETL sinh ra)
data/store_*/*.xlsx
data/store_*/*.xls
data/store_*/*.csv
data/store_*/*.json

# ── Database & Backup ───────────────────────────────────────
*.sqlite
*.db
sql/backups/
*.bak
*.bak.*

# ── Upload directory (runtime) ──────────────────────────────
uploads/
tmp/
temp/

# ── Docker runtime ──────────────────────────────────────────
.docker/
*.tar
superset_home/

# ── IDE & Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ── OS ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Claude / AI tools ───────────────────────────────────────
.agents/
.claude/

# ── Node (nếu có frontend build) ────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Báo cáo / file tạm sinh ra ──────────────────────────────
DOCKER_TEST_REPORT.md
zap_report.html
zap_full_report.html



#google json
frontend/instance/google_drive_connections.json
google_drive_connections.json
